// Cell Phone — key item with conditional text
//
// Variables set by engine: in_ruins, missed_calls

node OnUse {
    if in_ruins {
        text: "* You called Toriel."
        text: "* She didn't pick up..."
    } else {
        text: "* No signal."
    }
}

node OnCheck {
    if missed_calls > 0 {
        text: $"* An old cell phone. {missed_calls} missed calls."
    } else {
        text: "* An old cell phone."
    }
}

// KeyItem has no OnDrop — engine skips DropItem for KeyItem
