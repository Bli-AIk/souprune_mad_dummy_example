// 蔬菜人 ACT 对话节点

node act_check {
    text: "* 蔬菜人 - 攻击 6 防御 6"
    text: "* 份量：1只怪物。"
    text: "* 未经食品安全局检测。"
}

node act_talk {
    text: "* 你与蔬菜人交谈。"
    text: "* "植物不会说话，笨蛋。""
}

node act_dinner {
    text: "* 你邀请蔬菜人一起吃晚餐。"
    text: "* 蔬菜人提供了健康的一餐。"
}

node act_devour {
    text: "* 你尝试吃掉蔬菜人。"
    text: "* 它对这个想法感到不舒服。"
}

node act_flirt {
    text: "* 你向蔬菜人眨眼。"
    text: "* 蔬菜人看起来困惑但高兴。"
}

node act_pat {
    text: "* 你轻拍蔬菜人。"
    text: "* 它的叶子愉快地沙沙作响。"
}
