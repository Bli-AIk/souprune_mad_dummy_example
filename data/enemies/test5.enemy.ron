// Vegetoid enemy definition (6 ACT options)
// 蔬菜人敌人定义 (6 个 ACT 选项)
(
    id: "vegetoid",
    locale: (name: "{{battle/ui:ENEMY_VEGETOID}}", file: "enemies"),
    stats: (hp: 200, attack: 6, defense: 6),
    description: "Serving Size: 1 Monster. Not monitored by the USDA.",
    mortar_path: "battle/enemies/vegetoid.mortar",
    acts: [
        (label: "{{battle/ui:ACT_VEGETOID_CHECK}}", sequence: "states/battle/common/narration.sequence.ron", param: "act_check"),
        (label: "{{battle/ui:ACT_VEGETOID_TALK}}", sequence: "states/battle/common/narration.sequence.ron", param: "act_talk"),
        (label: "{{battle/ui:ACT_VEGETOID_DINNER}}", sequence: "states/battle/common/narration.sequence.ron", param: "act_dinner"),
        (label: "{{battle/ui:ACT_VEGETOID_DEVOUR}}", sequence: "states/battle/common/narration.sequence.ron", param: "act_devour"),
        (label: "{{battle/ui:ACT_VEGETOID_FLIRT}}", sequence: "states/battle/common/narration.sequence.ron", param: "act_flirt"),
        (label: "{{battle/ui:ACT_VEGETOID_PAT}}", sequence: "states/battle/common/narration.sequence.ron", param: "act_pat"),
    ],
    mercies: [
        (label: "{{battle/ui:MERCY_SPARE}}", sequence: "states/battle/mercy/end.sequence.ron"),
        (label: "{{battle/ui:MERCY_FLEE}}", sequence: "states/battle/mercy/end.sequence.ron"),
    ],
)
