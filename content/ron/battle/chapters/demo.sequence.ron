#![enable(implicit_some)]
// Mad Dummy battle — example mod
// Mad Dummy 战斗 — 示例 mod
(
    mode: "battle",
    chapters: [
        // === Mod-specific Init / Mod 特定初始化 ===
        SetBgm(path: "mus_dummybattle.ogg", fade_in: 0.5),

        LoadEnemies(enemies: [
            "actors/enemies/mad_dummy.enemy.ron",
        ]),
        SpawnView(view_layout: "battle/view/mad_dummy.view.ron"),

        SpawnView(view_layout: "battle/view/battle_bg.view.ron"),
        SpawnView(
            view_layout: "battle/view/undertale.view.ron",
            bindings: { "enemies": LocalLayer },
        ),

        AwaitFact(condition: "$view_rules_loaded == true", local: true),
        EmitFactEvent(event_id: "battle:show_intro"),

        // === Delegate to preset battle loop / 委托给预设战斗循环 ===
        // turn_narration: per-turn narration handled by demo_turn_narration.sequence.ron
        // (turn 0 = encounter intro, turn 1+ = random flavor text)
        RunSequence(
            path: "battle/templates/undertale_battle.sequence.ron",
            params: {
                "enemy_id": String("mad_dummy"),
                "turn_narration": String("battle/chapters/demo_turn_narration.sequence.ron"),
            },
        ),
    ],
)
