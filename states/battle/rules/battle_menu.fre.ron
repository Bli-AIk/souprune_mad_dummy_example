#![enable(implicit_some)]
// Battle Menu Navigation Rules
// depth 0: Main menu (FIGHT/ACT/ITEM/MERCY), depth 1: Submenu, depth 2: ACT options

(
    scope: View,
    rules: [
        // ========================================
        // DIALOGUE STOP HANDLER
        // 对话停止处理
        // ========================================
        // Clear dialogue state when dialogue:stop event is received
        // 当收到 dialogue:stop 事件时清除对话状态
        (event: Event("dialogue:stop"),
         actions: [SetLocalFact("dialogue_text", String("")), SetLocalFact("dialogue_visible", Bool(false))]),

        // Main menu (depth 0) - horizontal navigation
        (event: ActionEvent(action: "Left", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 0", "$button_selection > 0"],
         actions: [SetLocalFact("button_selection", Expr("$button_selection - 1")), PlaySound("choice")]),

        (event: ActionEvent(action: "Right", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 0", "$button_selection < 3"],
         actions: [SetLocalFact("button_selection", Expr("$button_selection + 1")), PlaySound("choice")]),

        // Submenu (depth 1) - enemy list navigation (non-ITEM)
        (event: ActionEvent(action: "Up", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 1", "$menu_context != 2", "$enemy_selection > 0", "$enemy_selection > $enemy_view_offset"],
         actions: [SetLocalFact("enemy_selection", Expr("$enemy_selection - 1")), PlaySound("choice")]),

        (event: ActionEvent(action: "Up", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 1", "$menu_context != 2", "$enemy_selection > 0", "$enemy_selection <= $enemy_view_offset"],
         actions: [SetLocalFact("enemy_selection", Expr("$enemy_selection - 1")), SetLocalFact("enemy_view_offset", Expr("$enemy_view_offset - 1")), PlaySound("choice")]),

        (event: ActionEvent(action: "Down", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 1", "$menu_context != 2", "$enemy_selection < $enemy_names - 1", "$enemy_selection < $enemy_view_offset + $enemy_display_limit - 1"],
         actions: [SetLocalFact("enemy_selection", Expr("$enemy_selection + 1")), PlaySound("choice")]),

        (event: ActionEvent(action: "Down", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 1", "$menu_context != 2", "$enemy_selection < $enemy_names - 1", "$enemy_selection >= $enemy_view_offset + $enemy_display_limit - 1"],
         actions: [SetLocalFact("enemy_selection", Expr("$enemy_selection + 1")), SetLocalFact("enemy_view_offset", Expr("$enemy_view_offset + 1")), PlaySound("choice")]),

        // Submenu (depth 1) - item list navigation (ITEM mode)
        (event: ActionEvent(action: "Up", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 1", "$menu_context == 2", "$item_selection > 0"],
         actions: [SetLocalFact("item_selection", Expr("$item_selection - 1")), PlaySound("choice")]),

        (event: ActionEvent(action: "Down", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 1", "$menu_context == 2", "$item_selection < 7"],
         actions: [SetLocalFact("item_selection", Expr("$item_selection + 1")), PlaySound("choice")]),

        // Confirm: main menu -> submenu
        (event: ActionEvent(action: "Confirm", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 0"],
         actions: [SetLocalFact("menu_context", Expr("$button_selection")), SetLocalFact("depth", Int(1)), SetLocalFact("enemy_selection", Int(0)), SetLocalFact("item_selection", Int(0)), PlaySound("confirm")]),

        // Confirm: submenu ACT -> ACT options
        (event: ActionEvent(action: "Confirm", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 1", "$menu_context == 1"],
         actions: [SetLocalFact("current_enemy_id", Expr("$enemy_ids[$enemy_selection]")), SetLocalFact("act_count", Expr("$${current_enemy_id}.act_count")), SetLocalFact("action_labels", Expr("$${current_enemy_id}.action_labels")), SetLocalFact("action_sequences", Expr("$${current_enemy_id}.action_sequences")), SetLocalFact("action_params", Expr("$${current_enemy_id}.action_params")), SetLocalFact("depth", Int(2)), SetLocalFact("act_selection", Int(0)), PlaySound("confirm")]),

        // Confirm: submenu MERCY -> MERCY options
        (event: ActionEvent(action: "Confirm", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 1", "$menu_context == 3"],
         actions: [SetLocalFact("current_enemy_id", Expr("$enemy_ids[$enemy_selection]")), SetLocalFact("mercy_count", Expr("$${current_enemy_id}.mercy_count")), SetLocalFact("mercy_labels", Expr("$${current_enemy_id}.mercy_labels")), SetLocalFact("mercy_sequences", Expr("$${current_enemy_id}.mercy_sequences")), SetLocalFact("mercy_params", Expr("$${current_enemy_id}.mercy_params")), SetLocalFact("depth", Int(2)), SetLocalFact("mercy_selection", Int(0)), PlaySound("confirm")]),

        // Confirm: submenu FIGHT -> execute (no depth 2)
        (event: ActionEvent(action: "Confirm", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 1", "$menu_context == 0"],
         actions: [SetLocalFact("selection_confirmed", Bool(true)), SetLocalFact("interactable", Bool(false)), SetLocalFact("pending_sequence", String("")), PlaySound("confirm"), EmitEvent("battle_action_executed")]),

        // Confirm: submenu ITEM -> execute (no depth 2)
        (event: ActionEvent(action: "Confirm", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 1", "$menu_context == 2"],
         actions: [SetLocalFact("selection_confirmed", Bool(true)), SetLocalFact("interactable", Bool(false)), SetLocalFact("pending_sequence", String("")), PlaySound("confirm"), EmitEvent("battle_action_executed")]),

        // Confirm: ACT options -> execute
        (event: ActionEvent(action: "Confirm", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 2", "$menu_context == 1"],
         actions: [SetLocalFact("action_param", Expr("$${current_enemy_id}.action_params[$act_selection]")), SetLocalFact("mortar_path", Expr("$${current_enemy_id}.mortar_path")), SetLocalFact("pending_sequence", Expr("$${current_enemy_id}.action_sequences[$act_selection]")), SetLocalFact("selection_confirmed", Bool(true)), SetLocalFact("interactable", Bool(false)), PlaySound("confirm")]),

        // Confirm: MERCY options -> execute
        (event: ActionEvent(action: "Confirm", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 2", "$menu_context == 3"],
         actions: [SetLocalFact("action_param", Expr("$mercy_params[$mercy_selection]")), SetLocalFact("mortar_path", Expr("$${current_enemy_id}.mortar_path")), SetLocalFact("pending_sequence", Expr("$mercy_sequences[$mercy_selection]")), SetLocalFact("selection_confirmed", Bool(true)), SetLocalFact("interactable", Bool(false)), PlaySound("confirm")]),

        // ACT options (depth 2) - 2-column grid navigation
        (event: ActionEvent(action: "Left", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 2", "$menu_context == 1", "$act_selection % 2 == 1"],
         actions: [SetLocalFact("act_selection", Expr("$act_selection - 1")), PlaySound("choice")]),

        (event: ActionEvent(action: "Right", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 2", "$menu_context == 1", "$act_selection % 2 == 0", "$act_selection + 1 < $act_count"],
         actions: [SetLocalFact("act_selection", Expr("$act_selection + 1")), PlaySound("choice")]),

        (event: ActionEvent(action: "Up", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 2", "$menu_context == 1", "$act_selection >= 2"],
         actions: [SetLocalFact("act_selection", Expr("$act_selection - 2")), PlaySound("choice")]),

        (event: ActionEvent(action: "Down", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 2", "$menu_context == 1", "$act_selection + 2 < $act_count"],
         actions: [SetLocalFact("act_selection", Expr("$act_selection + 2")), PlaySound("choice")]),

        // MERCY options (depth 2) - single column navigation
        (event: ActionEvent(action: "Up", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 2", "$menu_context == 3", "$mercy_selection > 0"],
         actions: [SetLocalFact("mercy_selection", Expr("$mercy_selection - 1")), PlaySound("choice")]),

        (event: ActionEvent(action: "Down", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 2", "$menu_context == 3", "$mercy_selection < $mercy_count - 1"],
         actions: [SetLocalFact("mercy_selection", Expr("$mercy_selection + 1")), PlaySound("choice")]),

        // Cancel: ACT/MERCY options -> submenu
        (event: ActionEvent(action: "Cancel", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 2"],
         actions: [SetLocalFact("depth", Int(1)), SetLocalFact("act_selection", Int(0)), SetLocalFact("mercy_selection", Int(0))],
         consume_event: true, priority: 100),

        // Cancel: submenu -> main menu
        (event: ActionEvent(action: "Cancel", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 1"],
         actions: [SetLocalFact("depth", Int(0)), SetLocalFact("enemy_selection", Int(0)), SetLocalFact("enemy_view_offset", Int(0))],
         consume_event: true, priority: 100),

        // Narration confirm
        (event: ActionEvent(action: "Confirm", kind: JustPressed),
         conditions: ["$narration_visible == true"],
         actions: [SetLocalFact("confirm_pressed", Bool(true))]),
    ],
)
