#![enable(implicit_some)]
// Battle Dialogue Test Rules — demonstrates FRE-driven dialogue system
// Dialogue Flow: Rule triggers → StartDialogue action → handle_pending_dialogue_start_system → spawns View/Mortar → dialogue:ended cleanup

(
    facts: {
        "test_dialogue_shown": Bool(false),
        "test_mortar_shown": Bool(false),
        "battle:intro_shown": Bool(false),
    },

    rules: [
        // Encounter intro narration (uses Mortar, no menu block)
        (id: "battle_encounter_intro", event: Event("battle:show_intro"),
         conditions: ["$battle:intro_shown == false"],
         modifications: [
             Set(key: "battle:intro_shown", value: Bool(true)),
         ],
         actions: [
             StartDialogue(mortar: "battle/ui.mortar", node: "encounter_intro", focus: false,
                           voice: "audios/voice/voice_typewriter_default.wav"),
             Log(message: "Battle: Starting encounter intro"),
         ],
         priority: 100),

        // Simple text narration test
        (id: "test_simple_narration", event: Event("test_simple_narration"),
         conditions: ["$test_dialogue_shown == false"],
         modifications: [
             Set(key: "dialogue:simple_text_active", value: Bool(true)),
             Set(key: "dialogue:simple_text", value: String("* 这是一条测试旁白。\n* Your soul is filled with determination.")),
             Set(key: "dialogue:has_typewriter", value: Bool(true)),
             Set(key: "dialogue:has_focus", value: Bool(true)),
             Set(key: "test_dialogue_shown", value: Bool(true)),
         ],
         priority: 10),

        (id: "test_simple_narration_ended", event: Event("dialogue:ended"),
         conditions: ["$dialogue:simple_text_active == true"],
         modifications: [
             Set(key: "dialogue:simple_text_active", value: Bool(false)),
             Set(key: "dialogue:simple_text", value: String("")),
             Set(key: "dialogue:has_focus", value: Bool(false)),
         ],
         priority: 10),

        // Mortar dialogue test
        (id: "test_mortar_dialogue", event: Event("test_mortar_dialogue"),
         conditions: ["$test_mortar_shown == false"],
         modifications: [
             Set(key: "test_mortar_shown", value: Bool(true)),
         ],
         actions: [
             StartDialogue(mortar: "dialogue/test/battle_test.mortar", node: "act_greeting"),
         ],
         priority: 10),

        // Battle dialogue lifecycle
        (id: "battle_dialogue_started", event: Event("dialogue:started"),
         modifications: [Set(key: "battle:paused_for_dialogue", value: Bool(true))],
         priority: 5),

        (id: "battle_dialogue_ended", event: Event("dialogue:ended"),
         modifications: [
             Set(key: "dialogue:has_focus", value: Bool(false)),
             Set(key: "battle:paused_for_dialogue", value: Bool(false)),
             Remove("dialogue:pending_mortar_path"),
             Remove("dialogue:pending_mortar_node"),
             Remove("dialogue:pending_view"),
         ],
         priority: 5),

        // ACT with dialogue (e.g., Check action)
        (id: "act_with_dialogue", event: Event("battle:execute_act"),
         conditions: ["$act_type == 'check'"],
         actions: [
             StartDialogue(mortar: "dialogue/enemies/dummy.mortar", node: "check"),
         ],
         priority: 10),
    ],
)
