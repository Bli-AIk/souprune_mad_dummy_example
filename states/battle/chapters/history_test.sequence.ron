#![enable(implicit_some)]
// History System Test Battle Chapter
// 历史系统测试战斗章节
//
// This chapter comprehensively tests the ViewElement history system:
// - Multiple modifications
// - Undo/Redo with various states
// - Reset operations
// - Edge cases
//
// 这个章节全面测试 ViewElement 历史系统：
// - 多次修改
// - 各种状态的撤销/重做
// - 重置操作
// - 边界情况

(
    chapters: [
        SetCamera(SetZoom(2.0)),
        // === Initial UI Setup ===
        // === 初始 UI 设置 ===
        SpawnView(view_layout: "states/battle/view/undertale.view.ron"),
        Wait(0.5),
            
            // === Test 1: Simple SetPosition ===
            // === 测试 1: 简单的位置设置 ===
            // Original position: (0, -80, 0)
            // 原始位置: (0, -80, 0)
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: SetPosition(-100.0, 0.0, 0.0),
            ),
            Wait(0.8),
            
            // Undo should return to (0, -80, 0)
            // 撤销应该返回到 (0, -80, 0)
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Undo,
            ),
            Wait(0.8),
            
            // Redo should move back to (-100, 0, 0)
            // 重做应该移回 (-100, 0, 0)
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Redo,
            ),
            Wait(0.8),
            
            // === Test 2: Multiple SetPosition calls ===
            // === 测试 2: 多次位置设置 ===
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: SetPosition(0.0, 50.0, 0.0),
            ),
            Wait(0.8),
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: SetPosition(100.0, 50.0, 0.0),
            ),
            Wait(0.8),
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: SetPosition(100.0, -50.0, 0.0),
            ),
            Wait(0.8),
            
            // Undo 3 times: (100, -50) -> (100, 50) -> (0, 50) -> (-100, 0)
            // 撤销 3 次: (100, -50) -> (100, 50) -> (0, 50) -> (-100, 0)
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Undo,
            ),
            Wait(0.6),
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Undo,
            ),
            Wait(0.6),
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Undo,
            ),
            Wait(0.8),
            
            // Redo 2 times: (-100, 0) -> (0, 50) -> (100, 50)
            // 重做 2 次: (-100, 0) -> (0, 50) -> (100, 50)
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Redo,
            ),
            Wait(0.6),
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Redo,
            ),
            Wait(0.8),
            
            // === Test 3: Reset from middle of history ===
            // === 测试 3: 从历史中间重置 ===
            
            // Reset should go back to original (0, -80, 0)
            // 重置应该返回到原始位置 (0, -80, 0)
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Reset,
            ),
            Wait(1.0),
            
            // === Test 4: Branch history (modify after undo) ===
            // === 测试 4: 分支历史（撤销后修改）===
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: SetPosition(-50.0, 0.0, 0.0),
            ),
            Wait(0.6),
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: SetPosition(50.0, 0.0, 0.0),
            ),
            Wait(0.6),
            
            // Undo once: (50, 0) -> (-50, 0)
            // 撤销一次: (50, 0) -> (-50, 0)
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Undo,
            ),
            Wait(0.6),
            
            // New modification should discard the (50, 0) state
            // 新的修改应该丢弃 (50, 0) 状态
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: SetPosition(0.0, 80.0, 0.0),
            ),
            Wait(0.8),
            
            // Redo should fail (redo stack was cleared)
            // 重做应该失败（重做栈已清除）
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Redo,
            ),
            Wait(0.8),
            
            // === Test 5: SetPosition (with expressions and random) ===
            // === 测试 5: 设置位置（带表达式和随机数） ===
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: SetPosition("@current", "random(50.0)", 0.0),  // Static X (@current), Random Y in [-50, 50]
            ),
            Wait(0.8),
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: SetPosition("@current", "random(-30.0, 30.0)", 0.0),  // Random Y in [-30, 30]
            ),
            Wait(0.8),
            
            // Undo twice to go back through random positions
            // 撤销两次以回退随机位置
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Undo,
            ),
            Wait(0.6),
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Undo,
            ),
            Wait(0.8),
            
            // === Test 6: Edge case - Undo at original state ===
            // === 测试 6: 边界情况 - 在原始状态撤销 ===
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Reset,
            ),
            Wait(0.6),
            
            // This undo should fail (already at original)
            // 这个撤销应该失败（已经在原始状态）
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Undo,
            ),
            Wait(0.8),
            
            // === Test 7: Multiple resets ===
            // === 测试 7: 多次重置 ===
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: SetPosition(75.0, 75.0, 0.0),
            ),
            Wait(0.6),
            
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Reset,
            ),
            Wait(0.6),
            
            // Reset again (should stay at original)
            // 再次重置（应该停留在原始位置）
            ModifyViewElement(
                selector: LocalName("BattleBox"),
                modification: Reset,
            ),
            Wait(1.0),
            
        // === End Test ===
        // === 结束测试 ===
    ],
)
