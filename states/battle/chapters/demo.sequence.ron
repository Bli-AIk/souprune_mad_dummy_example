#![enable(implicit_some)]
// Mad Dummy battle — example mod
// Mad Dummy 战斗 — 示例 mod
(
    mode: "battle",
    chapters: [
        // === Mod-specific Init / Mod 特定初始化 ===
        SetCamera(SetZoom(2.0)),
        SetBgm(path: "mus_dummybattle.ogg", fade_in: 0.5),

        LoadEnemies(enemies: [
            "data/enemies/mad_dummy.enemy.ron",
        ]),

        SpawnView(view_layout: "states/battle/view/mad_dummy.view.ron"),
        SpawnView(view_layout: "states/battle/view/battle_bg.view.ron"),
        SpawnView(
            view_layout: "states/battle/view/undertale.view.ron",
            bindings: { "enemies": LocalLayer },
        ),

        AwaitFact(condition: "$view_rules_loaded == true", local: true),
        EmitFactEvent(event_id: "battle:show_intro"),

        // Intro narration — non-blocking, shown alongside player menu
        // In Undertale, encounter text plays while buttons are already interactive.

        SetViewFact(key: "narration_visible", value: Bool(true)),
        SetViewFact(key: "dialogue:replay_on_resume", value: Bool(true)),
        ModifyFact(
            modifications: [
                Set(key: "dialogue:pending_mortar_path", value: String("battle/ui.mortar")),
                Set(key: "dialogue:pending_mortar_node", value: String("encounter_intro")),
                Set(key: "dialogue:pending_start", value: Bool(true)),
                Set(key: "dialogue:has_typewriter", value: Bool(true)),
                Set(key: "dialogue:has_focus", value: Bool(false)),
                Set(key: "dialogue:voice", value: String("audios/voice/voice_typewriter_default.wav")),
            ],
        ),

        // === Delegate to preset battle loop / 委托给预设战斗循环 ===
        RunSequence(
            path: "states/battle/templates/undertale_battle.sequence.ron",
            params: { "enemy_id": String("mad_dummy") },
        ),
    ],
)
