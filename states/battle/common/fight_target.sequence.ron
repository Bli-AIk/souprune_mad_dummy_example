// FIGHT target sequence — attack bar sweep + target collapse
// FIGHT 攻击目标序列 — 攻击条扫描 + 目标收缩
//
// Flow:
//   1. Clear UI (stop dialogue, hide buttons, clear text)
//   2. Show DumbTarget + AttackBar
//   3. Sweep AttackBar left→right (1.5s total)
//      During the LAST 0.5s of the sweep, simultaneously:
//      - AttackBar fades out (alpha → 0)
//      - DumbTarget linearly shrinks (scale X → 0) and fades out
//   4. Clean up (hide elements, reset transforms)
//
// Timing reference: Undertale attack bar at ~11px/frame @ 30fps
(chapters: [
    // Stop any playing dialogue
    // 停止任何正在播放的对话
    EmitFactEvent(event_id: "dialogue:stop"),

    // Disable typewriter replay during fight animation
    // 在战斗动画期间禁用打字机重播
    SetViewFact(key: "dialogue:replay_on_resume", value: Bool(false)),

    // Clear UI: hide menus, clear dialogue text
    // 清除 UI：隐藏菜单，清除对话文本
    SetViewFact(key: "depth", value: Int(0)),
    SetViewFact(key: "buttons_visible", value: Bool(false)),
    SetViewFact(key: "dialogue_text", value: String("")),

    // Show DumbTarget + AttackBar
    // 显示攻击目标 + 攻击条
    SetViewFact(key: "fight_target_visible", value: Bool(true)),

    // Phase 1: bar sweeps to near the end (1.45s, ~97% of distance)
    // 第一阶段：攻击条扫到接近终点（1.45 秒，约 97% 距离）
    TweenViewElement(
        selector: LocalName("AttackBar"),
        target: Position(to: (254.0, -80.5, 11.0)),
        duration: 1.45,
        easing: Linear,
        wait_for_completion: true,
    ),

    // Phase 2: remaining sweep (0.05s) + fade/collapse (0.4s) in parallel
    // 第二阶段：剩余扫过（0.05 秒）+ 渐出/收缩（0.4 秒）并行
    Parallel([
        // Bar finishes sweep
        // 攻击条到达终点
        TweenViewElement(
            selector: LocalName("AttackBar"),
            target: Position(to: (272.0, -80.5, 11.0)),
            duration: 0.05,
            easing: Linear,
            wait_for_completion: true,
        ),
        // Bar fade out
        // 攻击条渐出
        TweenViewElement(
            selector: LocalName("AttackBar"),
            target: Alpha(to: 0.0),
            duration: 0.4,
            easing: Linear,
            wait_for_completion: true,
        ),
        // DumbTarget horizontal scale collapse
        // DumbTarget 横向缩放收缩
        TweenViewElement(
            selector: LocalName("DumbTarget"),
            target: Scale(to: (0.0, 1.0, 1.0)),
            duration: 0.4,
            easing: Linear,
            wait_for_completion: true,
        ),
        // DumbTarget fade out
        // DumbTarget 渐出
        TweenViewElement(
            selector: LocalName("DumbTarget"),
            target: Alpha(to: 0.0),
            duration: 0.4,
            easing: Linear,
            wait_for_completion: true,
        ),
    ]),

    // Hide elements
    // 隐藏元素
    SetViewFact(key: "fight_target_visible", value: Bool(false)),

    // Reset transforms for next turn
    // 重置变换以备下一回合
    ModifyViewElement(
        selector: LocalName("AttackBar"),
        modification: Reset,
    ),
    ModifyViewElement(
        selector: LocalName("DumbTarget"),
        modification: Reset,
    ),

    // Restore UI state
    // 恢复 UI 状态
    SetViewFact(key: "buttons_visible", value: Bool(true)),
    SetViewFact(key: "dialogue:replay_on_resume", value: Bool(true)),
])
