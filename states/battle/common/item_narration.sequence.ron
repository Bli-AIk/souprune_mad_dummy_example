// Item narration sequence — manages UI visibility while UseItem dialogue plays
// 物品旁白序列 — 在 UseItem 对话播放期间管理 UI 可见性
//
// Unlike the generic narration.sequence.ron, this does NOT start dialogue.
// UseItem action has already started the dialogue; this sequence just
// manages narration visibility and waits for the dialogue to finish.
//
// 与通用 narration.sequence.ron 不同，此序列不启动对话。
// UseItem 动作已启动对话；此序列仅管理旁白可见性并等待对话结束。
(chapters: [
    SetViewFact(key: "dialogue:replay_on_resume", value: Bool(false)),

    // Hide menu, show narration area
    SetViewFact(key: "depth", value: Int(0)),
    SetViewFact(key: "buttons_visible", value: Bool(false)),
    SetViewFact(key: "narration_visible", value: Bool(true)),

    // Dialogue already started by UseItem — wait for it to activate and finish
    AwaitFact(condition: "$dialogue:active == true", local: false),
    AwaitFact(condition: "$dialogue:active == false", local: false),

    // Restore UI
    SetViewFact(key: "narration_visible", value: Bool(false)),
    SetViewFact(key: "buttons_visible", value: Bool(true)),
    SetViewFact(key: "dialogue_text", value: String("")),
    SetViewFact(key: "dialogue:replay_on_resume", value: Bool(true)),
])
