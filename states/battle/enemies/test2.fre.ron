// Whimsun enemy definition (3 ACT options)
// 小哭虫敌人定义 (3 个 ACT 选项)
(
    facts: {
        "whimsun.name": String("{{battle/ui:ENEMY_WHIMSUN}}"),
        "whimsun.hp": Int(80),
        "whimsun.hp_max": Int(100),
        "whimsun.attack": Int(5),
        "whimsun.defense": Int(0),
        "whimsun.description": String("This monster is too sensitive to fight."),

        // ACT options count
        "whimsun.act_count": Int(3),

        // Action option display labels (Mortar localization keys)
        "whimsun.action_labels": StringList([
            "{{battle/ui:ACT_WHIMSUN_CHECK}}",
            "{{battle/ui:ACT_WHIMSUN_CONSOLE}}",
            "{{battle/ui:ACT_WHIMSUN_TERRORIZE}}",
        ]),

        // Sequence paths for each action option
        "whimsun.action_sequences": StringList([
            "states/battle/common/narration.sequence.ron",
            "states/battle/common/narration.sequence.ron",
            "states/battle/common/narration.sequence.ron",
        ]),

        // Mortar node names for each action's dialogue
        "whimsun.action_params": StringList([
            "act_check",
            "act_console",
            "act_terrorize",
        ]),

        // Mortar dialogue file path (relative to shared/locales/{locale}/)
        "whimsun.mortar_path": String("battle/enemies/whimsun.mortar"),

        // MERCY options (default: no dialogue, direct end)
        "whimsun.mercy_count": Int(2),
        "whimsun.mercy_labels": StringList([
            "{{battle/ui:MERCY_SPARE}}",
            "{{battle/ui:MERCY_FLEE}}",
        ]),
        "whimsun.mercy_sequences": StringList([
            "states/battle/mercy/end.sequence.ron",
            "states/battle/mercy/end.sequence.ron",
        ]),
        "whimsun.mercy_params": StringList([
            "",
            "",
        ]),
    },
    rules: [],
)
