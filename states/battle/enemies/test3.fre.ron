            "{{battle/ui:ACT_MOLDSMAL_IMITATE}}",
            "{{battle/ui:ACT_MOLDSMAL_FLIRT}}",
            "{{battle/ui:ACT_MOLDSMAL_UNHUG}}",
        ]),

        // Sequence paths for each action option
        "moldsmal.action_sequences": StringList([
            "states/battle/common/narration.sequence.ron",
            "states/battle/common/narration.sequence.ron",
            "states/battle/common/narration.sequence.ron",
            "states/battle/common/narration.sequence.ron",
        ]),

        // Mortar node names for each action's dialogue
        "moldsmal.action_params": StringList([
            "act_check",
            "act_imitate",
            "act_flirt",
            "act_unhug",
        ]),

        // Mortar dialogue file path (relative to shared/locales/{locale}/)
        "moldsmal.mortar_path": String("battle/enemies/moldsmal.mortar"),

        // MERCY options (default: no dialogue, direct end)
        "moldsmal.mercy_count": Int(2),
        "moldsmal.mercy_labels": StringList([
            "{{battle/ui:MERCY_SPARE}}",
            "{{battle/ui:MERCY_FLEE}}",
        ]),
        "moldsmal.mercy_sequences": StringList([
