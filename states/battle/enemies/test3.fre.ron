        "moldsmal.defense": Int(0),
        "moldsmal.description": String("Stereotypical: Curvaceously attractive, but no brains."),

        // ACT options count
        "moldsmal.act_count": Int(4),

        // Action option display labels (Mortar localization keys)
        "moldsmal.action_labels": StringList([
