// Battle enemies data - directly used by battle UI
// 战斗敌人数据 - 直接被战斗 UI 使用
//
// This file contains aggregated enemy data for battle UI consumption.
// All arrays must have the same length.
//
// 此文件包含聚合的敌人数据，供战斗 UI 使用。
// 所有数组必须有相同的长度。

(
    facts: {
        // Enemy IDs (used to look up ACT data from enemy FRE files)
        // 敌人 ID（用于从敌人 FRE 文件查找 ACT 数据）
        "enemy_ids": StringList([
            "froggit",
            "whimsun",
            "moldsmal",
            "loox",
            "vegetoid",
        ]),

        // Enemy names (localized)
        // 敌人名称（本地化）
        "enemy_names": StringList([
            "{{battle/ui:ENEMY_FROGGIT}}",
            "{{battle/ui:ENEMY_WHIMSUN}}",
            "{{battle/ui:ENEMY_MOLDSMAL}}",
            "{{battle/ui:ENEMY_LOOX}}",
            "{{battle/ui:ENEMY_VEGETOID}}",
        ]),

        // Current HP values
        // 当前生命值
        "enemy_hps": IntList([100, 80, 120, 60, 150]),

        // Maximum HP values
        // 最大生命值
        "enemy_hp_maxs": IntList([100, 100, 150, 80, 200]),

        // Attack values
        // 攻击值
        "enemy_attacks": IntList([4, 5, 6, 6, 6]),

        // Defense values
        // 防御值
        "enemy_defenses": IntList([5, 0, 0, 6, 6]),
    },
    rules: [],
)
