// Dummy enemy definition
// Dummy 敌人定义
//
// This file defines the Dummy enemy using FRE format.
// Facts are loaded when this enemy is added to a battle.
// Rules handle enemy-specific actions and behaviors.
//
// 此文件使用 FRE 格式定义 Dummy 敌人。
// 当此敌人被添加到战斗时，事实会被加载。
// 规则处理敌人特定的动作和行为。

(
    // Enemy data as initial facts
    // These are merged into the battle's fact database
    // 作为初始事实的敌人数据
    // 这些会被合并到战斗的事实数据库中
    facts: {
        // Basic enemy stats
        // 基本敌人属性
        "dummy.name": String("Dummy"),
        "dummy.hp": Int(100),
        "dummy.hp_max": Int(100),
        "dummy.attack": Int(0),
        "dummy.defense": Int(0),

        // Encounter description
        // 遭遇描述
        "dummy.description": String("A cotton heart and a button eye."),

        // =========================================================================
        // Generic action system facts
        // These use abstract naming for maximum reusability across ACT/ITEM/MERCY
        //
        // 通用行动系统 facts
        // 使用抽象命名以最大化复用于 ACT/ITEM/MERCY
        // =========================================================================

        // ACT options count
        // ACT 选项数量
        "dummy.act_count": Int(4),

        // Action option display labels (Mortar localization keys)
        // 动作选项显示标签（Mortar 本地化键）
        "dummy.action_labels": StringList([
            "EnemyDummyActCheck",
            "EnemyDummyActTalk",
            "EnemyDummyActFlirt",
            "EnemyDummyActHug",
        ]),

        // Sequence paths for each action option
        // 每个动作选项对应的序列路径
        "dummy.action_sequences": StringList([
            "states/battle/common/narration.sequence.ron",
            "states/battle/common/narration.sequence.ron",
            "states/battle/acts/dummy/flirt.sequence.ron",
            "states/battle/common/narration.sequence.ron",
        ]),

        // Mortar node names for each action's dialogue
        // 每个动作对话的 Mortar 节点名
        "dummy.action_params": StringList([
            "act_check",
            "act_talk",
            "",
            "act_hug",
        ]),

        // Mortar dialogue file path (relative to shared/locales/{locale}/)
        // Mortar 对话文件路径（相对于 shared/locales/{locale}/）
        "dummy.mortar_path": String("battle/enemies/dummy.mortar"),

        // =========================================================================
        // MERCY options
        // MERCY 选项
        // =========================================================================

        // MERCY options count
        // MERCY 选项数量
        "dummy.mercy_count": Int(2),

        // MERCY option display labels (Mortar localization keys)
        // MERCY 选项显示标签（Mortar 本地化键）
        "dummy.mercy_labels": StringList([
            "{{battle/ui:MERCY_SPARE}}",
            "{{battle/ui:MERCY_FLEE}}",
        ]),

        // Sequence paths for each MERCY option
        // 每个 MERCY 选项对应的序列路径
        "dummy.mercy_sequences": StringList([
            "states/battle/mercy/spare.sequence.ron",
            "states/battle/mercy/end.sequence.ron",
        ]),

        // Mortar node names for each MERCY option's dialogue
        // 每个 MERCY 选项对话的 Mortar 节点名
        "dummy.mercy_params": StringList([
            "mercy_spare",
            "",
        ]),
    },

    // Enemy-specific rules
    // These handle ACT options, damage reactions, etc.
    // 敌人特定规则
    // 处理行动选项、受伤反应等
    rules: [],
)
