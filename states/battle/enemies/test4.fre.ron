// Loox enemy definition (5 ACT options)
// 独眼怪敌人定义 (5 个 ACT 选项)
(
    facts: {
        "loox.name": String("{{battle/ui:ENEMY_LOOX}}"),
        "loox.hp": Int(60),
        "loox.hp_max": Int(80),
        "loox.attack": Int(6),
        "loox.defense": Int(6),
        "loox.description": String("Don't pick on him. Family name: Eyewalker."),

        // ACT options count
        "loox.act_count": Int(5),

        // Action option display labels (Mortar localization keys)
        "loox.action_labels": StringList([
            "{{battle/ui:ACT_LOOX_CHECK}}",
            "{{battle/ui:ACT_LOOX_PICKOFF}}",
            "{{battle/ui:ACT_LOOX_DONTPICK}}",
            "{{battle/ui:ACT_LOOX_STARE}}",
            "{{battle/ui:ACT_LOOX_FLIRT}}",
        ]),

        // Sequence paths for each action option
        "loox.action_sequences": StringList([
            "states/battle/common/narration.sequence.ron",
            "states/battle/common/narration.sequence.ron",
            "states/battle/common/narration.sequence.ron",
            "states/battle/common/narration.sequence.ron",
            "states/battle/common/narration.sequence.ron",
        ]),

        // Mortar node names for each action's dialogue
        "loox.action_params": StringList([
            "act_check",
            "act_pickoff",
            "act_dontpick",
            "act_stare",
            "act_flirt",
        ]),

        // Mortar dialogue file path (relative to shared/locales/{locale}/)
        "loox.mortar_path": String("battle/enemies/loox.mortar"),

        // MERCY options (default: no dialogue, direct end)
        "loox.mercy_count": Int(2),
        "loox.mercy_labels": StringList([
            "{{battle/ui:MERCY_SPARE}}",
            "{{battle/ui:MERCY_FLEE}}",
        ]),
        "loox.mercy_sequences": StringList([
            "states/battle/mercy/end.sequence.ron",
            "states/battle/mercy/end.sequence.ron",
        ]),
        "loox.mercy_params": StringList([
            "",
            "",
        ]),
    },
    rules: [],
)
